# .env の見本（実際の鍵は書かない）
#
# betterleaks の動作を試す手順:
#   1. この見本を .env にコピー        cp .env.example .env
#   2. 下の secret を本物っぽいダミー40桁に差し替え（高エントロピーな英数字）
#   3. コミットを試す                  git add -f .env && git commit -m test
#      → betterleaks が止める（leaks found: 1 → コミット中止）
#   4. 後始末                          git restore --staged .env && rm .env
#
# AWS_ACCESS_KEY_ID の値は AWS 公式サンプル（betterleaks は無視＝この見本は安全に commit できる）

AWS_ACCESS_KEY_ID=AKIAIOSFODNN7EXAMPLE
AWS_SECRET_ACCESS_KEY=__REPLACE_WITH_A_DUMMY_40CHAR_SECRET__
